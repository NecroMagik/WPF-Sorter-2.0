<controls:MetroWindow
    x:Class="WPF_Sorter_2._0.Views.UpdateDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:converters="clr-namespace:WPF_Sorter_2._0.Converters"
    Title="Обновление доступно"
    Height="520"
    Width="580"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStyle="SingleBorderWindow"
    AllowsTransparency="False">

	<controls:MetroWindow.Resources>
		<converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
		<converters:BooleanInverterConverter x:Key="BooleanInverterConverter" />
	</controls:MetroWindow.Resources>

	<Border
        Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
        CornerRadius="12"
        Padding="28">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<!-- Заголовок -->
			<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12" HorizontalAlignment="Center">
				<TextBlock
                    Text="▼"
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="{DynamicResource SystemAccentBrush}"
                    Margin="0,0,12,0" />
				<TextBlock
                    Text="Доступно обновление!"
                    FontSize="22"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource SystemAccentBrush}" />
			</StackPanel>

			<!-- Информация о версиях -->
			<Grid Grid.Row="1" Margin="0,0,0,12">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<TextBlock
                    Grid.Column="0"
                    Text="Текущая:"
                    Foreground="{DynamicResource MahApps.Brushes.Gray6}"
                    Margin="0,0,8,0" />
				<TextBlock
                    Grid.Column="1"
                    Text="{Binding CurrentVersion}"
                    FontWeight="SemiBold" />
				<TextBlock
                    Grid.Column="2"
                    Text="Новая:"
                    Foreground="{DynamicResource MahApps.Brushes.Gray6}"
                    Margin="16,0,8,0" />
				<TextBlock
                    Grid.Column="3"
                    Text="{Binding NewVersion}"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource SystemAccentBrush}" />
			</Grid>

			<!-- Разделитель -->
			<Border
                Grid.Row="2"
                Background="{DynamicResource MahApps.Brushes.Gray8}"
                Height="1"
                Margin="0,0,0,12" />

			<!-- Описание изменений -->
			<ScrollViewer
                Grid.Row="3"
                MaxHeight="100"
                VerticalScrollBarVisibility="Auto"
                Margin="0,0,0,12">
				<TextBlock
                    Text="{Binding Changelog}"
                    TextWrapping="Wrap"
                    FontSize="13"
                    Foreground="{DynamicResource MahApps.Brushes.Text}"
                    LineHeight="20" />
			</ScrollViewer>

			<!-- Информация о файле и прогресс -->
			<StackPanel Grid.Row="4" Margin="0,0,0,12">
				<TextBlock
                    Text="{Binding AssetInfo}"
                    FontSize="12"
                    Foreground="{DynamicResource MahApps.Brushes.Gray6}"
                    TextWrapping="Wrap"
                    Margin="0,0,0,8" />

				<!-- Прогресс-бар -->
				<ProgressBar
                    x:Name="DownloadProgressBar"
                    Value="{Binding DownloadProgress}"
                    Minimum="0"
                    Maximum="100"
                    Height="20"
                    Foreground="{DynamicResource SystemAccentBrush}"
                    Background="{DynamicResource MahApps.Brushes.Gray8}"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}" />

				<TextBlock
                    Text="{Binding DownloadStatus}"
                    FontSize="12"
                    Foreground="{DynamicResource MahApps.Brushes.Gray6}"
                    HorizontalAlignment="Center"
                    Margin="0,4,0,0"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}" />
			</StackPanel>

			<!-- Кнопки -->
			<StackPanel
                Grid.Row="5"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Margin="0,4,0,0">
				<Button
                    Content="Скачать и установить"
                    Command="{Binding InstallCommand}"
                    Foreground="White"
                    FontWeight="SemiBold"
                    FontSize="14"
                    Width="200"
                    Height="44"
                    BorderThickness="0"
                    Cursor="Hand"
                    IsEnabled="{Binding IsDownloading, Converter={StaticResource BooleanInverterConverter}}">
					<Button.Template>
						<ControlTemplate TargetType="Button">
							<Border
                                Background="{DynamicResource SystemAccentBrush}"
                                CornerRadius="8"
                                Padding="16,0">
								<ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
							</Border>
							<ControlTemplate.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter Property="Opacity" Value="0.9" />
								</Trigger>
								<Trigger Property="IsPressed" Value="True">
									<Setter Property="Opacity" Value="0.8" />
								</Trigger>
								<Trigger Property="IsEnabled" Value="False">
									<Setter Property="Opacity" Value="0.5" />
								</Trigger>
							</ControlTemplate.Triggers>
						</ControlTemplate>
					</Button.Template>
				</Button>

				<Button
                    Content="Скачать в фоне"
                    Command="{Binding BackgroundDownloadCommand}"
                    Style="{DynamicResource MahApps.Styles.Button}"
                    Width="160"
                    Height="44"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Margin="12,0,0,0"
                    Foreground="{DynamicResource MahApps.Brushes.Text}"
                    IsEnabled="{Binding IsDownloading, Converter={StaticResource BooleanInverterConverter}}" />

				<Button
                    Content="Отложить"
                    Command="{Binding CancelCommand}"
                    Style="{DynamicResource MahApps.Styles.Button}"
                    Width="120"
                    Height="44"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Margin="12,0,0,0"
                    Foreground="{DynamicResource MahApps.Brushes.Text}" />
			</StackPanel>

			<!-- Статус в фоне -->
			<TextBlock
                Grid.Row="6"
                Text="{Binding BackgroundDownloadStatus}"
                FontSize="12"
                Foreground="{DynamicResource MahApps.Brushes.Gray6}"
                HorizontalAlignment="Center"
                Margin="0,8,0,0"
                Visibility="{Binding IsBackgroundDownloading, Converter={StaticResource BooleanToVisibilityConverter}}" />
		</Grid>
	</Border>
</controls:MetroWindow>