<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Эти ресурсы будут заменены в коде -->
    <SolidColorBrush x:Key="SystemAccentBrush" Color="#0078D7" />
    <SolidColorBrush x:Key="SystemAccentLightBrush" Color="#400078D7" />

    <!-- Эти ресурсы тоже будут переопределены в коде -->
    <SolidColorBrush x:Key="MahApps.Brushes.Accent" Color="#0078D7" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent2" Color="#0078D7" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent3" Color="#0078D7" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent4" Color="#0078D7" />
    <SolidColorBrush x:Key="MahApps.Brushes.AccentBase" Color="#0078D7" />
    <SolidColorBrush x:Key="MahApps.Brushes.AccentColorBrush" Color="#0078D7" />

    <Color x:Key="MahApps.Colors.Accent">#0078D7</Color>
    <Color x:Key="MahApps.Colors.AccentBase">#0078D7</Color>

</ResourceDictionary>